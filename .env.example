# Khora Environment Variables
# Copy to .env and customize

# =============================================================================
# Database (required for full functionality)
# =============================================================================
# PostgreSQL connection (use localhost:5434 when running databases with docker compose)
KHORA_DATABASE_URL=postgresql://khora:khora@localhost:5434/khora

# Neo4j connection (optional, for graph features)
# KHORA_NEO4J_URL=bolt://neo4j:khora@localhost:7688

# =============================================================================
# Application
# =============================================================================
KHORA_DEBUG=false
KHORA_ENVIRONMENT=development
KHORA_LOG_LEVEL=INFO

# =============================================================================
# API Server
# =============================================================================
KHORA_API_HOST=127.0.0.1
KHORA_API_PORT=8000

# =============================================================================
# Authentication
# =============================================================================
# Set to false for local development
KHORA_AUTH_ENABLED=false

# =============================================================================
# Docker Compose (optional overrides)
# Ports are intentionally non-standard to avoid conflicts with other projects
# =============================================================================
# POSTGRES_PORT=5434
# NEO4J_HTTP_PORT=7475
# NEO4J_BOLT_PORT=7688
# NEO4J_PASSWORD=khora
